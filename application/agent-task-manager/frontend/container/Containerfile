ARG NODE_IMAGE=docker.io/library/node:22-bookworm
ARG NGINX_IMAGE=docker.io/library/nginx:1.29-alpine

FROM ${NODE_IMAGE} AS builder

WORKDIR /src
COPY application/agent-task-manager/frontend/package.json ./package.json
COPY application/agent-task-manager/frontend/tsconfig.json ./tsconfig.json
COPY application/agent-task-manager/frontend/vite.config.ts ./vite.config.ts
COPY application/agent-task-manager/frontend/index.html ./index.html
COPY application/agent-task-manager/frontend/src ./src
RUN npm install && npm run build

FROM ${NGINX_IMAGE}

COPY application/agent-task-manager/frontend/container/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /src/dist /usr/share/nginx/html
