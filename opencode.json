{
  "provider": {
    "openai": {
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}",
        "headerTimeout": 120000,
        "timeout": 1200000,
        "chunkTimeout": 120000,
        "filterSseFrame": ["chatcmpl-dummy", "chatcmpl-ws-ingress"]
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "deepseek": {
      "options": {
        "baseURL": "{env:DEEPSEEK_BASE_URL}",
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "headerTimeout": 120000,
        "timeout": 1200000,
        "chunkTimeout": 120000
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "limit": {
            "context": 800000,
            "output": 32768
          },
          "options": {
            "store": false
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 800000,
            "output": 65536
          },
          "options": {
            "store": false
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "options": {
        "store": false
      }
    },
    "plan": {
      "options": {
        "store": false
      }
    }
  },
  "model": "deepseek/deepseek-v4-pro",
  "instructions": [
    ".opencode/AGENTS.md"
  ],
  "autoupdate": false,
  "$schema": "https://opencode.ai/config.json"
}
